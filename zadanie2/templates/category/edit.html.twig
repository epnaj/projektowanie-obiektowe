{% extends 'base.html.twig' %}

{% block title %}Edytuj kategorię: {{ category.name }}{% endblock %}

{% block body %}
    <h1>Edytuj kategorię</h1>
    <div class="card">
        <form method="POST" action="/categories/{{ category.id }}/edit">
            <div class="form-group">
                <label for="name">Nazwa</label>
                <input type="text" id="name" name="name" value="{{ category.name }}" required>
            </div>
            <div class="form-group">
                <label for="description">Opis</label>
                <textarea id="description" name="description">{{ category.description }}</textarea>
            </div>
            <button type="submit" class="btn btn-success">Zapisz</button>
            <a href="/categories" class="btn btn-secondary">Anuluj</a>
        </form>
    </div>
{% endblock %}
