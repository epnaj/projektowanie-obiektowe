{% extends 'base.html.twig' %}

{% block title %}Kategorie{% endblock %}

{% block body %}
    <h1>Kategorie</h1>
    <a href="/categories/new" class="btn btn-success" style="margin-bottom: 1rem;">Dodaj kategorię</a>
    <table>
        <thead>
            <tr>
                <th>ID</th>
                <th>Nazwa</th>
                <th>Opis</th>
                <th>Akcje</th>
            </tr>
        </thead>
        <tbody>
            {% for category in categories %}
                <tr>
                    <td>{{ category.id }}</td>
                    <td>{{ category.name }}</td>
                    <td>{{ category.description ?? '-' }}</td>
                    <td class="actions">
                        <a href="/categories/{{ category.id }}" class="btn btn-primary">Pokaż</a>
                        <a href="/categories/{{ category.id }}/edit" class="btn btn-secondary">Edytuj</a>
                        <form class="inline" method="POST" action="/categories/{{ category.id }}/delete" onsubmit="return confirm('Czy na pewno chcesz usunąć?')">
                            <button type="submit" class="btn btn-danger">Usuń</button>
                        </form>
                    </td>
                </tr>
            {% else %}
                <tr><td colspan="4">Brak kategorii.</td></tr>
            {% endfor %}
        </tbody>
    </table>
{% endblock %}
